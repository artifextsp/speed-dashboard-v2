# Permisos necesarios: repo (contenido)
VITE_GITHUB_PAT=ghp_tu_token_aqui
VITE_GITHUB_OWNER=artifextsp
VITE_GITHUB_REPO=PILOTO
VITE_GITHUB_BRANCH=main

# URL del sitio de estudiantes (para verificar si está desactualizado)
VITE_PUBLIC_SITE_URL=https://www.proyectospeed.com

